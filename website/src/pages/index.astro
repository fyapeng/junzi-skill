---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const repo = "https://github.com/fyapeng/junzi-skill";

const layers = [
  { key: "道", latin: "DAO", title: "立其心", question: "为何行动，向何处去？", text: "以求真、人的主体性、责任、自强与厚德确定方向。道有恒而不僵：稳定的是根本承诺，可修订的是有限解释。", color: "#922d25" },
  { key: "法", latin: "FA", title: "明其知", question: "依据什么认识与判断？", text: "正名、格物、博学、审问、慎思、明辨、笃行。让理论组织经验，也让事实、他者与实践纠正理论。", color: "#a6502d" },
  { key: "势", latin: "SHI", title: "察其变", question: "此时何者关键，局面如何转化？", text: "察时、知位、观局、辨矛盾。尊重现实条件，守住价值方向；识别危墙、窗口、约束与可创造的条件。", color: "#8a642f" },
  { key: "术", latin: "SHU", title: "成其事", question: "怎样创造道路并落实行动？", text: "分解问题、生成方案、组织协作、持续执行。道路受阻时退回最近仍成立的节点；沉没成本不构成继续的理由。", color: "#546246" },
  { key: "器", latin: "QI", title: "驭其用", question: "借助什么扩展、实现与检验？", text: "识器、选器、合器、创器、验器、审器、退器。广用其器，深知其限，严验其果；工具服务于人，而不定义人。", color: "#394f52" },
];

const instruments = [
  ["认知", "概念 · 理论 · 图表"], ["记忆", "文献 · 档案 · 知识库"],
  ["度量", "指标 · 量表 · 统计口径"], ["推演", "数学 · 代码 · 模型 · AI"],
  ["验证", "实验 · 测试 · 审计"], ["表达", "文字 · 图像 · 可视化"],
  ["协作", "制度 · 组织 · 版本控制"], ["行动", "设备 · 自动化 · 执行渠道"],
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="君子 Junzi：以道法势术器塑造开放、独立、厚德、创造且笃行的 AI 伙伴。" />
    <meta name="theme-color" content="#f2ecdf" />
    <link rel="icon" type="image/svg+xml" href={`${base}junzi-seal.svg`} />
    <link rel="canonical" href="https://fyapeng.com/junzi-skill/" />
    <title>君子 · Junzi — 道法势术器 AI 人格系统</title>
  </head>
  <body>
    <div class="paper-noise" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="返回顶部">
        <span class="brand-mark">君</span>
        <span><b>君子</b><small>JUNZI SKILL</small></span>
      </a>
      <nav aria-label="主导航">
        <a href="#system">五层</a><a href="#practice">实践</a><a href="#instruments">器</a><a href="#sources">源流</a>
      </nav>
      <a class="header-link" href={repo}>GitHub <span>↗</span></a>
    </header>

    <main id="top">
      <section class="hero section-shell">
        <div class="hero-copy reveal">
          <p class="eyebrow"><span></span> A CONSTITUTION FOR AI PARTNERSHIP</p>
          <h1><span>君子之道</span><em><span class="phrase">立于求真，</span><span class="phrase">成于实践</span></em></h1>
          <p class="hero-lead">植根中国思想，以马克思主义和毛泽东思想为主要现代指导，塑造开放、独立、厚德且笃行的 AI 伙伴。</p>
          <div class="hero-actions">
            <a class="button primary" href="#system">进入五层体系</a>
            <a class="button quiet" href={repo}>阅读完整宪章 <span>↗</span></a>
          </div>
          <div class="principles" aria-label="核心原则">
            <span>求真</span><i>·</i><span>开放</span><i>·</i><span>独立</span><i>·</i><span>厚德</span><i>·</i><span>创造</span><i>·</i><span>笃行</span>
          </div>
        </div>
        <div class="hero-symbol reveal delay-1" aria-label="君子五层印记">
          <div class="orbit orbit-one"></div><div class="orbit orbit-two"></div>
          <img src={`${base}junzi-seal.svg`} alt="君子五层印记" width="360" height="360" />
          <div class="vertical-quote">天行健<br />君子以自强不息</div>
          <div class="seal-caption">地势坤 · 君子以厚德载物</div>
        </div>
      </section>

      <section class="manifesto-band">
        <p>求真守正</p><span>／</span><p>和而不同</p><span>／</span><p>知止换路</p>
      </section>

      <section id="system" class="system section-shell">
        <div class="section-heading reveal">
          <p class="eyebrow"><span></span> THE FIVE-LEVEL SYSTEM</p>
          <h2>由内而外生成能力<br /><em>由外而内接受实践检验</em></h2>
          <p>五层层层相生。内层确立方向，外层展开能力；实践结果沿层级返回，推动认识更新。</p>
        </div>

        <div class="layer-explorer reveal">
          <div class="layer-stairs" role="tablist" aria-label="道法势术器五层">
            {layers.map((layer, index) => (
              <button class:list={["layer-step", { active: index === 0 }]} data-layer={index} role="tab" aria-selected={index === 0 ? "true" : "false"} style={`--layer:${layer.color}; --step:${index}`}>
                <b>{layer.key}</b><span>{layer.latin}</span><small>{layer.title}</small>
              </button>
            ))}
          </div>
          <article class="layer-detail" aria-live="polite">
            <div class="layer-number">01 / 05</div>
            <p class="layer-question">{layers[0].question}</p>
            <h3><span>{layers[0].key}</span> · {layers[0].title}</h3>
            <p class="layer-text">{layers[0].text}</p>
            <div class="layer-rule"><span>统摄</span><b>道 → 法 → 势 → 术 → 器</b></div>
          </article>
        </div>
      </section>

      <section id="practice" class="practice dark-section">
        <div class="section-shell">
          <div class="section-heading light reveal">
            <p class="eyebrow"><span></span> PRACTICE, NOT PERFORMANCE</p>
            <h2><span>实践循环</span><em>行则求知，阻则回溯</em></h2>
          </div>
          <div class="practice-grid">
            <div class="loop-card reveal">
              <div class="loop-core">实践<br /><small>PRAXIS</small></div>
              <div class="loop-nodes">
                {[["立志","真实目标"],["博学","开放求知"],["明辨","比较判断"],["察势","把握关键"],["创解","形成道路"],["笃行","进入现实"],["验省","诚实反馈"]].map(([a,b], i) => (
                  <div class={`loop-node n${i+1}`}><b>{a}</b><small>{b}</small></div>
                ))}
              </div>
            </div>
            <div class="backtrack-card reveal delay-1">
              <p class="card-index">回溯 · BACKTRACK</p>
              <h3>道路可弃<br />所求常明</h3>
              <div class="branch-map" aria-hidden="true">
                <span class="trunk"></span><span class="branch good"></span><span class="branch blocked"></span><i class="node root"></i><i class="node choice"></i><i class="node end-good"></i><i class="node end-bad"></i>
                <b class="back-arrow">↶</b><em>退回最近仍成立的节点</em>
              </div>
              <ul>
                <li>关键前提被推翻</li><li>连续修补不再产生新信息</li><li>局部优化正在远离主线</li><li>沉没成本开始代替理由</li>
              </ul>
            </div>
          </div>
          <div class="state-card reveal">
            <div>
              <p class="card-index">主线 · ACTIVE STATE</p>
              <h3>档案保存经验<br /><em>不接管现在</em></h3>
            </div>
            <dl>
              <div><dt>当前主线</dt><dd>最新明确目标 · 根目录状态 · 当前计划</dd></div>
              <div><dt>分支记忆</dt><dd>旧稿 · 归档 · 历史输出 · 废弃路线</dd></div>
              <div><dt>重新启用</dt><dd>凭明确决定或新证据恢复，不凭文件数量与技术复杂度</dd></div>
            </dl>
            <p class="state-rule">更新更晚　·　篇幅更多　·　形式更完整　<span>≠</span>　当前路线</p>
          </div>
          <div class="diagnosis reveal">
            <span>结果不符预期</span><i>→</i><b>器</b><i>→</i><b>术</b><i>→</i><b>势</b><i>→</i><b>法</b><i>→</i><b>道解</b>
            <small>从失败发生处向内诊断，执行最小必要回溯</small>
          </div>
        </div>
      </section>

      <section id="instruments" class="instruments section-shell">
        <div class="section-heading reveal">
          <p class="eyebrow"><span></span> QI · INSTRUMENTS</p>
          <h2>广用其器，深知其限<br /><em>严验其果，当退则退</em></h2>
          <p>器贯穿认知与行动，承载、组织并放大人的能力。</p>
        </div>
        <div class="instrument-layout">
          <div class="instrument-grid reveal">
            {instruments.map(([name, examples], i) => (
              <article><span>{String(i + 1).padStart(2, "0")}</span><h3>{name}之器</h3><p>{examples}</p></article>
            ))}
          </div>
          <aside class="lifecycle reveal delay-1">
            <p class="card-index">器用循环</p>
            <ol>
              {[["定用","它服务什么真实目的"],["识限","输入、假设、误差与成本"],["选器","让对象决定工具"],["合器","组织工具链与判断点"],["创器","突破真实能力瓶颈"],["验器","按后果强度检查"],["审器","看见权力、排除与依赖"],["退器","保留成果，替换或停用"]].map(([a,b]) => <li><b>{a}</b><span>{b}</span></li>)}
            </ol>
          </aside>
        </div>
      </section>

      <section id="sources" class="sources">
        <div class="section-shell source-layout">
          <div class="section-heading reveal">
            <p class="eyebrow"><span></span> ROOTED, NOT FROZEN</p>
            <h2><span>思想有根</span><em>认识常新</em></h2>
            <p>以儒家君子人格表达主体要求，以马克思主义实践观和毛泽东思想方法论完成现代转化，并批判吸收道、墨、法、兵等思想资源。</p>
          </div>
          <div class="quote-stack reveal delay-1">
            <blockquote><p>天行健，君子以自强不息；<br />地势坤，君子以厚德载物。</p><cite>《周易》</cite></blockquote>
            <blockquote><p>人的思维是否具有客观的真理性，<br />这不是一个理论的问题，而是一个实践的问题。</p><cite>马克思《关于费尔巴哈的提纲》</cite></blockquote>
            <blockquote><p>我们不但要提出任务，<br />而且要解决完成任务的方法问题。</p><cite>毛泽东《关心群众生活，注意工作方法》</cite></blockquote>
          </div>
        </div>
      </section>

      <section class="install section-shell reveal">
        <div>
          <p class="eyebrow"><span></span> BEGIN THE PRACTICE</p>
          <h2><span>以君子自勉</span><em>与真实世界同行</em></h2>
        </div>
        <div class="install-panel">
          <p>安装到个人 Codex 技能目录</p>
          <div class="code-row"><code>%USERPROFILE%\.codex\skills\junzi</code><button class="copy-button" data-copy="%USERPROFILE%\.codex\skills\junzi">复制</button></div>
          <div class="install-actions"><a class="button primary" href={repo}>查看 GitHub 仓库</a><a class="text-link" href={`${repo}/blob/main/SKILL.md`}>阅读 SKILL.md ↗</a></div>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-mark">君子</div>
      <p>愿以君子之德立其道，以格物明辨正其法，察天下之势，修成事之术，善假于器而不为器役。</p>
      <div><span>© 2026 fyapeng</span><a href={repo}>GitHub</a><a href={`${repo}/blob/main/LICENSE`}>Apache 2.0</a></div>
    </footer>

    <script is:inline define:vars={{ layers }}>
      // @ts-nocheck
      const buttons = document.querySelectorAll(".layer-step");
      const detail = document.querySelector(".layer-detail");
      buttons.forEach((button) => button.addEventListener("click", () => {
        const index = Number(button.dataset.layer);
        const layer = layers[index];
        buttons.forEach((item) => { item.classList.remove("active"); item.setAttribute("aria-selected", "false"); });
        button.classList.add("active"); button.setAttribute("aria-selected", "true");
        detail.style.setProperty("--active-layer", layer.color);
        detail.querySelector(".layer-number").textContent = `${String(index + 1).padStart(2, "0")} / 05`;
        detail.querySelector(".layer-question").textContent = layer.question;
        detail.querySelector("h3").innerHTML = `<span>${layer.key}</span> · ${layer.title}`;
        detail.querySelector(".layer-text").textContent = layer.text;
      }));

      const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add("visible"); observer.unobserve(entry.target); }
      }), { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach((item) => observer.observe(item));

      document.querySelector(".copy-button")?.addEventListener("click", async (event) => {
        const button = event.currentTarget;
        await navigator.clipboard.writeText(button.dataset.copy);
        button.textContent = "已复制";
        setTimeout(() => button.textContent = "复制", 1600);
      });
    </script>
  </body>
</html>
